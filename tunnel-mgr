#!/usr/bin/env bash
# tunnel-mgr - Unified V2Ray/Xray Tunnel Manager
#
# A complete management tool for managing multiple V2Ray/Xray SOCKS5 tunnels
# behind a single HAProxy load balancer entry point.
#
# Use case: Iranian VPS that needs to access international services through
# multiple V2Ray providers, with automatic failover and health monitoring.
#
# Usage:
#   sudo bash tunnel-mgr               # interactive menu
#   sudo bash tunnel-mgr setup         # first-time setup (HAProxy + cron)
#   sudo bash tunnel-mgr status        # show pool status
#   sudo bash tunnel-mgr add NAME      # add a new tunnel
#   sudo bash tunnel-mgr remove NAME   # remove a tunnel
#   sudo bash tunnel-mgr test NAME     # deep test a tunnel
#   sudo bash tunnel-mgr test-all      # deep test all tunnels
#   sudo bash tunnel-mgr pause NAME    # pause a tunnel for 2 hours
#   sudo bash tunnel-mgr resume NAME   # resume a paused tunnel
#   sudo bash tunnel-mgr health        # quick health check (cron)
#   sudo bash tunnel-mgr reload        # rebuild HAProxy config

set -uo pipefail

# ═══════════════════════════════════════════════════════════
#   Configuration
# ═══════════════════════════════════════════════════════════
WORK_DIR="${TUNNEL_MGR_HOME:-/home/ubuntu/v2ray}"
CONFIG_DIR="$WORK_DIR/configs"
STATE_DIR="$WORK_DIR/state"
LOGS_DIR="$WORK_DIR/logs"
DATA_DIR="$WORK_DIR/data"
TEST_RESULTS="$WORK_DIR/test-results"
MANAGER_DIR="$WORK_DIR/manager"
STATE_FILE="$STATE_DIR/tunnels.json"
HAPROXY_CONF="/etc/haproxy/haproxy.cfg"
HAPROXY_BACKUP="$STATE_DIR/haproxy.cfg.original"
SOCKS_PORT_BASE=10810
HAPROXY_LISTEN_PORT=1080
HAPROXY_STATS_PORT=8404
KEYS_FILE="${TUNNEL_MGR_KEYS:-/home/ubuntu/.api_keys}"
DIRECT_HOSTS_FILE="$DATA_DIR/iran-direct-hosts.txt"
XRAY_BIN="/usr/local/bin/xray"

mkdir -p "$CONFIG_DIR" "$STATE_DIR" "$LOGS_DIR" "$DATA_DIR" "$TEST_RESULTS" "$MANAGER_DIR"

# ═══════════════════════════════════════════════════════════
#   Colors and helpers
# ═══════════════════════════════════════════════════════════
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
RED='\033[0;31m'
BLUE='\033[0;34m'
GRAY='\033[0;90m'
BOLD='\033[1m'
NC='\033[0m'

log()  { echo -e "${BLUE}[$(date +%H:%M:%S)]${NC} $*"; }
ok()   { echo -e "${GREEN}✅${NC} $*"; }
warn() { echo -e "${YELLOW}⚠️ ${NC} $*"; }
err()  { echo -e "${RED}❌${NC} $*"; }
info() { echo -e "${GRAY}ℹ️ ${NC} $*"; }

require_root() {
    if [ "$EUID" -ne 0 ]; then
        err "این کار نیاز به sudo دارد. اجرا: sudo bash $0 $*"
        exit 1
    fi
}

require_deps() {
    local missing=()
    for cmd in jq curl bc haproxy; do
        if ! command -v "$cmd" >/dev/null 2>&1; then
            missing+=("$cmd")
        fi
    done
    if [ ! -x "$XRAY_BIN" ]; then
        missing+=("xray")
    fi
    if [ ${#missing[@]} -gt 0 ]; then
        err "Dependencies نصب نیستند: ${missing[*]}"
        info "اجرا: sudo bash $0 setup"
        exit 1
    fi
}

