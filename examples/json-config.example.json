{
  "log": {
    "loglevel": "warning"
  },
  "inbounds": [
    {
      "tag": "socks-in",
      "port": 10811,
      "listen": "127.0.0.1",
      "protocol": "socks",
      "settings": {
        "auth": "noauth",
        "udp": false
      }
    }
  ],
  "outbounds": [
    {
      "tag": "proxy",
      "protocol": "vless",
      "settings": {
        "vnext": [{
          "address": "your-server.example.com",
          "port": 443,
          "users": [{
            "id": "00000000-0000-0000-0000-000000000000",
            "encryption": "none"
          }]
        }]
      },
      "streamSettings": {
        "network": "ws",
        "wsSettings": {
          "path": "/your-path",
          "host": "camouflage.example.com",
          "headers": { "Host": "camouflage.example.com" }
        }
      }
    }
  ]
}
